#!/usr/bin/env zsh
# Main zsh configuration file
# Loads modular configuration files in a specific order

# First, handle macOS path_helper if present
if [[ "${OSTYPE}" == "darwin"* && -x /usr/libexec/path_helper ]]; then
    eval "$(/usr/libexec/path_helper -s)"
fi

# Homebrew setup
if [[ "${OSTYPE}" == "darwin"* && -f "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ "${OSTYPE}" == "darwin"* && -f "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
elif [[ "${OSTYPE}" == "linux"* && -f "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [[ -f "${HOME}/.linuxbrew/bin/brew" ]]; then
    eval "$(${HOME}/.linuxbrew/bin/brew shellenv)"
fi

# Language-specific paths
if command -v go &>/dev/null; then
    export GOPATH="${HOME}/.go"
    PATH="${GOPATH}/bin:${PATH}"
fi

if [[ -d "${HOME}/.npm-global" ]]; then
    export NPM_CONFIG_PREFIX="${HOME}/.npm-global"
    PATH="${NPM_CONFIG_PREFIX}/bin:${PATH}"
fi

if command -v ruby &>/dev/null && command -v gem &>/dev/null; then
    export GEM_HOME="${HOME}/.gem"
    PATH="${GEM_HOME}/bin:${PATH}"
fi

# User directories
[[ -d "${HOME}/.local/bin" ]] && PATH="${HOME}/.local/bin:${PATH}"
[[ -d "${HOME}/Documents/Projects/dev-utils/bin" ]] && PATH="${PATH}:${HOME}/Documents/Projects/dev-utils/bin"

# Remove duplicate entries from PATH
typeset -U path

# Load modular configuration files in order
# Each file is responsible for a specific aspect of the shell configuration
for config_file in "${HOME}"/.zsh/[0-9][0-9]-*.zsh; do
    if [[ -r "$config_file" ]]; then
        source "$config_file"
    fi
done

# Cleanup
unset config_file
